{
  "manifest_version": 3,
  "name": "Tab Control",
  "key": "",
  "version": "1.0.0",
  "description": "Share browser tabs with AI agents for debugging and control",
  "permissions": ["debugger", "tabs", "nativeMessaging", "scripting", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Control",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
